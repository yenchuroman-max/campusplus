<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>КампусПлюс — ВКР 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#eaf0fb;--white:#fff;--line:#d9e2f1;--text:#18304f;--muted:#627998;--brand:#d77463;--brand2:#6f88c9;--ok:#29986e;--warn:#c78128;--shadow:0 22px 50px rgba(33,58,96,.13);--r:24px}
*{box-sizing:border-box}html,body{height:100%;margin:0}body{font-family:"Manrope",sans-serif;background:radial-gradient(circle at top left,rgba(215,116,99,.12),transparent 32%),radial-gradient(circle at top right,rgba(111,136,201,.11),transparent 26%),linear-gradient(180deg,#edf3fd,#e9eff9);color:var(--text);overflow:hidden}button{font:inherit}strong{color:var(--text)}
.stage{height:100%;padding:18px}.deck{position:relative;height:calc(100vh - 36px);max-width:1680px;margin:0 auto;overflow:hidden;border-radius:34px;background:rgba(255,255,255,.58);border:1px solid rgba(255,255,255,.9);box-shadow:0 28px 80px rgba(39,60,99,.16);backdrop-filter:blur(18px)}.ribbon{position:absolute;inset:0 auto auto 0;width:100%;height:7px;background:linear-gradient(90deg,var(--brand),var(--brand2),#63c1d8);z-index:3}
.slide{position:absolute;inset:0;padding:34px 42px 82px;display:grid;grid-template-rows:auto 1fr;gap:20px;opacity:0;pointer-events:none;transform:translateX(40px);transition:opacity .28s ease,transform .28s ease}.slide.active{opacity:1;pointer-events:auto;transform:none}.top{display:grid;grid-template-columns:1fr auto;gap:24px}.brand{display:flex;gap:18px;align-items:flex-start}.logo{width:76px;height:76px;border-radius:22px;background:#fff;border:1px solid rgba(255,255,255,.9);box-shadow:var(--shadow);display:grid;place-items:center;flex:none}.logo img{width:54px;height:54px;object-fit:contain}.meta{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px}.meta span{padding:8px 14px;border-radius:999px;border:1px solid var(--line);background:rgba(255,255,255,.82);color:#5c7394;font-size:12px;font-weight:800;letter-spacing:.04em;text-transform:uppercase}.num{padding:14px 20px;border-radius:20px;background:rgba(255,255,255,.92);border:1px solid var(--line);box-shadow:var(--shadow);font-size:14px;font-weight:800;color:#4b668e}
.body{display:grid;gap:18px;min-height:0}.hero{display:grid;grid-template-columns:minmax(0,1.08fr) minmax(0,.92fr);gap:22px;align-items:center}.two{grid-template-columns:repeat(2,minmax(0,1fr))}.twowide{grid-template-columns:minmax(0,1.08fr) minmax(0,.92fr)}.three{grid-template-columns:repeat(3,minmax(0,1fr))}.four{grid-template-columns:repeat(4,minmax(0,1fr))}.phones{grid-template-columns:repeat(5,minmax(0,1fr))}.people{grid-template-columns:repeat(3,minmax(0,1fr))}.three,.four,.phones,.people,.metricgrid,.shots2,.shots3,.flowcards{display:grid;gap:18px}.shots2{grid-template-columns:repeat(2,minmax(0,1fr))}.shots3{grid-template-columns:repeat(3,minmax(0,1fr))}.metricgrid{grid-template-columns:repeat(4,minmax(0,1fr))}
.card,.quote,.screen,.phone,.tablebox,.placeholder,.metric,.diag{background:rgba(255,255,255,.95);border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow)}.card,.quote,.placeholder,.metric,.diag{padding:22px 24px}.card p,.quote p,.placeholder p{margin:12px 0 0}.quote{background:linear-gradient(135deg,rgba(255,255,255,.98),rgba(243,247,255,.98))}.quote p{font-size:17px;line-height:1.65;color:#49617f}
h1,h2,h3,h4{font-family:"Space Grotesk","Manrope",sans-serif;letter-spacing:-.03em;margin:0;color:var(--text)}h1{font-size:clamp(42px,3.9vw,70px);line-height:.98;max-width:980px}h2{font-size:clamp(24px,2.1vw,40px);line-height:1.08;max-width:1060px}h3{font-size:clamp(17px,1.1vw,23px);line-height:1.15}p,li,td,th{font-size:15px;line-height:1.56;color:var(--muted)}.kicker{display:inline-flex;padding:8px 14px;border-radius:999px;background:linear-gradient(90deg,rgba(215,116,99,.12),rgba(111,136,201,.12));border:1px solid rgba(111,136,201,.22);color:#556d90;font-size:12px;font-weight:800;letter-spacing:.06em;text-transform:uppercase}
.tags{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}.tags span{padding:10px 14px;border-radius:999px;border:1px solid var(--line);background:#fff;font-size:13px;font-weight:700;color:#50698d}.person h4{margin-bottom:8px;color:#637b9a;font-size:13px;text-transform:uppercase}.person p{margin:0;color:var(--text);font-size:18px;font-weight:700}.list{margin:0;padding-left:20px;display:grid;gap:10px}.list li::marker{color:var(--brand)}
.tablebox{padding:0;overflow:hidden}table{width:100%;border-collapse:collapse}thead th{padding:16px;text-align:left;color:#587395;font-weight:800;background:linear-gradient(180deg,#f6f8fe,#edf2fb);border-bottom:1px solid var(--line)}tbody td{padding:14px 16px;border-bottom:1px solid #e7eef8;vertical-align:top}tbody tr:last-child td{border-bottom:none}.yes,.mid,.no,.pending{display:inline-flex;align-items:center;padding:6px 12px;border-radius:999px;font-size:12px;font-weight:800}.yes{background:rgba(41,152,110,.12);color:#1f825d}.mid{background:rgba(222,157,69,.16);color:var(--warn)}.no{background:rgba(215,116,99,.14);color:#b34f43}.pending{background:rgba(111,136,201,.12);color:#4969a0}
.screen,.phone{padding:14px 14px 18px;cursor:zoom-in}.bar{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:8px 10px 12px;color:#6b82a0;font-size:12px;font-weight:700}.dots{display:flex;gap:6px}.dots i{width:10px;height:10px;border-radius:50%;display:block;background:#f0b6aa}.dots i:nth-child(2){background:#f1d79f}.dots i:nth-child(3){background:#9fd7be}.screen img,.phone img{width:100%;display:block;border-radius:18px;border:1px solid #d9e2f1;background:#fff}.screen img{max-height:34vh;object-fit:cover}.phone img{max-height:30vh;object-fit:contain}figcaption{margin-top:12px;font-size:13px;color:#66809f}
.diagram-grid{display:grid;gap:12px}.uc{grid-template-columns:220px 1fr 220px;align-items:center}.classes{grid-template-columns:repeat(4,minmax(0,1fr))}.er{grid-template-columns:repeat(3,minmax(0,1fr))}.entity{padding:18px;border:1px solid var(--line);border-radius:22px;background:#fff}.entity h4{margin-bottom:10px}.entity ul{margin:0;padding-left:18px;display:grid;gap:6px}.actor{padding:18px;border-radius:22px;text-align:center;font-weight:800;background:linear-gradient(180deg,#fff,#f4f8ff);border:1px solid var(--line)}.uses{display:grid;gap:12px}.use{padding:14px 18px;border-radius:999px;border:1px solid var(--line);background:#fff;text-align:center;font-weight:700}.arrow{text-align:center;color:#6f88c9;font-weight:800;font-size:28px}.flowcards{grid-template-columns:repeat(5,minmax(0,1fr))}.flowstep{padding:18px;border:1px solid var(--line);border-radius:24px;background:#fff}.flowstep b{display:flex;width:38px;height:38px;border-radius:50%;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--brand),var(--brand2));color:#fff;margin-bottom:12px;font-family:"Space Grotesk"}.placeholder{display:grid;place-items:center;min-height:420px;text-align:center;background:linear-gradient(180deg,#fbfdff,#f4f8ff)}.placeholder .inner{max-width:720px}.metric b{display:block;font-size:28px;font-family:"Space Grotesk";margin-top:8px}.small{font-size:13px;color:#7f94b0}
.footer{position:absolute;left:32px;right:32px;bottom:22px;display:grid;grid-template-columns:auto 1fr auto;gap:14px;align-items:center;z-index:5}.nav{min-width:150px;padding:14px 18px;border:none;border-radius:16px;background:linear-gradient(90deg,#d87a66,#7890cc);color:#fff;font-weight:800;box-shadow:0 16px 34px rgba(76,101,146,.22);cursor:pointer}.nav.sec{background:#fff;color:#4f6788;border:1px solid var(--line);box-shadow:var(--shadow)}.counter{text-align:center;font-size:14px;font-weight:800;color:#637b99}.progress{height:8px;border-radius:999px;background:rgba(197,210,229,.7);overflow:hidden}.progress span{display:block;height:100%;width:0;border-radius:inherit;background:linear-gradient(90deg,var(--brand),var(--brand2),#63c1d8);transition:width .28s ease}
.lightbox{position:fixed;inset:0;background:rgba(18,31,54,.76);display:grid;place-items:center;padding:30px;opacity:0;pointer-events:none;transition:opacity .25s ease;z-index:40}.lightbox.open{opacity:1;pointer-events:auto}.lightbox figure{max-width:min(94vw,1700px);max-height:92vh;margin:0;display:grid;gap:10px}.lightbox img{width:100%;max-height:86vh;object-fit:contain;border-radius:24px;background:#fff;box-shadow:0 28px 60px rgba(0,0,0,.32)}.lightbox figcaption{text-align:center;color:rgba(255,255,255,.92);font-size:14px}.close{position:absolute;top:22px;right:22px;width:54px;height:54px;border:none;border-radius:50%;background:rgba(255,255,255,.18);color:#fff;font-size:30px;cursor:pointer}
@media (max-width: 1440px){.slide{padding:28px 34px 80px}h1{font-size:clamp(34px,3vw,58px)}h2{font-size:clamp(22px,1.75vw,34px)}.four,.metricgrid,.three,.shots3,.flowcards{grid-template-columns:repeat(2,minmax(0,1fr))}.phones{grid-template-columns:repeat(3,minmax(0,1fr))}.classes{grid-template-columns:repeat(2,minmax(0,1fr))}}
</style>
</head>
<body>
<div class="stage"><div class="deck"><div class="ribbon"></div>
<section class="slide active" data-title="Титульный слайд"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>СГУГиТ</span><span>Кафедра прикладной информатики и информационных систем</span><span>Выпускная квалификационная работа</span></div><div class="kicker">Титульный слайд</div></div></div><div class="num">01 / 27</div></div><div class="body"><div class="hero"><div><h1>Разработка веб-сервиса для мониторинга успеваемости с применением технологий искусственого интеллекта</h1><p style="max-width:880px;font-size:20px;line-height:1.7;color:#506985;margin:22px 0 0;">Выпускная квалификационная работа, посвящённая созданию прикладного веб-сервиса для преподавателя, объединяющего дисциплины, лекции, тестирование, QR-доступ и аналитику результатов обучающихся.</p><div class="people" style="margin-top:28px;"><article class="card person"><h4>Обучающийся</h4><p>Енчу Роман Викторович</p></article><article class="card person"><h4>Группа</h4><p>БИ-41</p></article><article class="card person"><h4>Руководитель</h4><p>Басаргин А.А.</p></article></div><article class="quote" style="margin-top:20px;"><h3>Сибирский государственный университет геосистем и технологий</h3><p>Кафедра прикладной информатики и информационных систем. Новосибирск, 2026 год.</p></article></div><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>campusplus</span></div><img src="presentation_assets/desktop/01_home_desktop.png" alt="Главная страница КампусПлюс"><figcaption>Демонстрационный экран разработанного веб-сервиса</figcaption></figure></div></div></section>
<section class="slide" data-title="Проблема"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 02</span><span>Проблема</span></div><h2>Подготовка и проведение контроля знаний требуют от преподавателя значительных временных затрат и большого объёма однотипной ручной работы</h2></div></div><div class="num">02 / 27</div></div><div class="body twowide"><div class="grid-2"><article class="card"><h3>Ручное создание тестов</h3><p>Преподавателю необходимо тратить время на подготовку вопросов, вариантов ответов, проверку формулировок и согласование содержания теста с темой лекции.</p></article><article class="card"><h3>Повторная валидация</h3><p>После подготовки тестов требуется повторно проверять корректность ответов, структуру материала и соответствие опубликованного теста образовательной задаче.</p></article><article class="card"><h3>Разрозненные инструменты</h3><p>Лекции, формы тестирования, результаты и аналитика часто располагаются в разных системах, из-за чего преподаватель теряет целостный контроль над процессом.</p></article><article class="card"><h3>Недостаток аналитики</h3><p>Без единого цифрового контура сложно быстро понять, какие дисциплины, темы и группы требуют внимания и методической доработки.</p></article></div><div><article class="quote"><h3>Решение проблемы</h3><p><strong>КампусПлюс</strong> формирует единый прикладной маршрут преподавателя: дисциплина → лекция → генерация или ручное создание теста → публикация → прохождение студентом → аналитика и точки роста.</p></article><article class="card" style="margin-top:18px;"><h3>Продуктовый эффект</h3><p>Система не просто хранит тесты, а сопровождает преподавателя на всём цикле работы с учебным материалом и последующей интерпретацией результатов.</p><div class="tags"><span>AI-генерация тестов</span><span>Ручной конструктор</span><span>QR-доступ</span><span>Аналитика по группам</span></div></article></div></div></section>
<section class="slide" data-title="Цель и задачи"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 03</span><span>Цель и задачи</span></div><h2>Цель проекта состоит в создании веб-сервиса, который покрывает полный цикл цифрового контроля знаний и снимает с преподавателя избыточную рутинную нагрузку</h2></div></div><div class="num">03 / 27</div></div><div class="body"><article class="quote"><h3>Цель работы</h3><p>Разработать веб-сервис для мониторинга успеваемости с применением технологий искусственого интеллекта, позволяющий связывать дисциплины, лекции, тестирование и результаты в единой информационной среде.</p></article><div class="three"><article class="card"><h3>Проанализировать предметную область</h3><p>Изучить ограничения существующих образовательных сервисов и выявить прикладные проблемы преподавателя.</p></article><article class="card"><h3>Сформировать требования</h3><p>Определить роли пользователей, ключевые сценарии и структуру учебных сущностей сервиса.</p></article><article class="card"><h3>Спроектировать модели</h3><p>Построить функциональные, процессные и информационно-логические модели предметной области.</p></article><article class="card"><h3>Разработать интерфейсы</h3><p>Реализовать рабочие контуры преподавателя, студента и администратора с адаптацией под реальные сценарии.</p></article><article class="card"><h3>Интегрировать AI-модуль</h3><p>Автоматизировать подготовку тестовых вопросов по лекционному материалу с возможностью ручного контроля.</p></article><article class="card"><h3>Подготовить демонстрационный стенд</h3><p>Показать работоспособность сервиса на реальных данных и типовых пользовательских сценариях.</p></article></div></div></section>
<section class="slide" data-title="Анализ существующих разработок"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 04</span><span>Анализ существующих разработок</span></div><h2>Существующие образовательные платформы решают отдельные задачи, но не формируют единый прикладной контур преподавателя</h2></div></div><div class="num">04 / 27</div></div><div class="body twowide"><article class="tablebox"><table><thead><tr><th>Критерий</th><th>Moodle</th><th>Google Forms</th><th>Stepik</th><th>КампусПлюс</th></tr></thead><tbody><tr><td><strong>Связь тестов с лекциями</strong></td><td><span class="mid">Частично</span></td><td><span class="no">Нет</span></td><td><span class="mid">Частично</span></td><td><span class="yes">Да</span></td></tr><tr><td><strong>AI-генерация вопросов</strong></td><td><span class="no">Нет</span></td><td><span class="no">Нет</span></td><td><span class="no">Нет</span></td><td><span class="yes">Да</span></td></tr><tr><td><strong>Ручной конструктор тестов</strong></td><td><span class="yes">Да</span></td><td><span class="mid">Базовый</span></td><td><span class="mid">Ограничен</span></td><td><span class="yes">Да</span></td></tr><tr><td><strong>QR-доступ на занятии</strong></td><td><span class="no">Нет</span></td><td><span class="no">Нет</span></td><td><span class="no">Нет</span></td><td><span class="yes">Да</span></td></tr><tr><td><strong>Аналитика по дисциплине, группе, студенту</strong></td><td><span class="mid">Есть, но перегружена</span></td><td><span class="no">Нет</span></td><td><span class="mid">Ориентир на курс</span></td><td><span class="yes">Да</span></td></tr><tr><td><strong>Быстрый сценарий для преподавателя</strong></td><td><span class="mid">Требует настройки</span></td><td><span class="mid">Слишком упрощён</span></td><td><span class="mid">Курсоцентрично</span></td><td><span class="yes">Да</span></td></tr></tbody></table></article><div><article class="quote"><h3>Вывод анализа</h3><p>Рынок предлагает либо универсальные LMS с избыточной сложностью настройки, либо упрощённые формы без связанной дисциплинарной аналитики. Наиболее рациональным решением является специализированный веб-сервис, ориентированный на прикладной маршрут преподавателя.</p></article><article class="card" style="margin-top:18px;"><h3>Преимущество выбранного подхода</h3><p>КампусПлюс проектируется не как абстрактная LMS, а как рабочий инструмент сопровождения дисциплины: от лекции до интерпретации результатов по конкретной группе.</p></article></div></div></section>
<section class="slide" data-title="Выбор программных средств"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 05</span><span>Выбор программных средств</span></div><h2>Для реализации проекта выбраны инструменты, обеспечивающие быстрый цикл разработки, интеграцию AI и удобную эксплуатацию</h2></div></div><div class="num">05 / 27</div></div><div class="body twowide"><article class="tablebox"><table><thead><tr><th>Критерий</th><th>Django</th><th>Node.js + Express</th><th>ASP.NET Core</th><th>FastAPI</th></tr></thead><tbody><tr><td><strong>Скорость старта проекта</strong></td><td><span class="mid">Средняя</span></td><td><span class="mid">Средняя</span></td><td><span class="mid">Средняя</span></td><td><span class="yes">Высокая</span></td></tr><tr><td><strong>Интеграция с Python AI</strong></td><td><span class="yes">Да</span></td><td><span class="no">Ограничено</span></td><td><span class="no">Ограничено</span></td><td><span class="yes">Да</span></td></tr><tr><td><strong>Асинхронная обработка</strong></td><td><span class="mid">Частично</span></td><td><span class="yes">Да</span></td><td><span class="yes">Да</span></td><td><span class="yes">Да</span></td></tr><tr><td><strong>Серверный HTML</strong></td><td><span class="yes">Да</span></td><td><span class="mid">Через шаблоны</span></td><td><span class="mid">Через Razor</span></td><td><span class="yes">Да</span></td></tr><tr><td><strong>Избыточность для MVP</strong></td><td><span class="no">Выше необходимой</span></td><td><span class="mid">Зависит от стека</span></td><td><span class="no">Выше необходимой</span></td><td><span class="yes">Оптимальная</span></td></tr></tbody></table></article><div><article class="quote"><h3>Выбранный стек</h3><p>В качестве платформы разработки выбран <strong>FastAPI</strong> в связке с <strong>Jinja2</strong>, <strong>HTML/CSS/JS</strong>, <strong>SQLite/PostgreSQL</strong> и AI-модулем генерации тестов. Такой набор обеспечивает быстрый прототип, ролевую модель и удобную интеграцию внешних моделей ИИ.</p></article><article class="card" style="margin-top:18px;"><h3>Технологии проекта</h3><div class="tags"><span>Python</span><span>FastAPI</span><span>Jinja2</span><span>SQLite / PostgreSQL</span><span>SessionMiddleware</span><span>OpenAI API</span><span>HTML / CSS / JS</span></div></article></div></div></section>
<section class="slide" data-title="Создание диаграммы прецедентов"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 06</span><span>Создание диаграммы прецедентов</span></div><h2>Диаграмма прецедентов отражает роли пользователей и основные варианты использования системы</h2></div></div><div class="num">06 / 27</div></div><div class="body twowide"><div class="diag"><h3>Диаграмма прецедентов</h3><div class="diagram-grid uc" style="margin-top:14px;"><div class="actor">Преподаватель</div><div class="uses"><div class="use">Создать лекцию</div><div class="use">Сгенерировать или собрать тест</div><div class="use">Редактировать и публиковать</div><div class="use">Просмотреть аналитику</div></div><div class="actor">Студент</div></div><div class="arrow">↓</div><div class="diagram-grid uc"><div class="actor">Администратор</div><div class="uses"><div class="use">Управлять пользователями</div><div class="use">Настраивать группы и преподавателей</div><div class="use">Сопровождать дисциплины</div></div><div class="actor">AI-модуль</div></div></div><div><article class="quote"><h3>Смысл диаграммы</h3><p>Ключевой пользователь системы — преподаватель. Именно его прикладной маршрут определяет основную ценность сервиса: создание контента, подготовка тестов, публикация доступа и анализ результатов.</p></article><article class="card" style="margin-top:18px;"><h3>Роли системы</h3><ul class="list"><li><strong>Преподаватель</strong> работает с дисциплинами, лекциями, тестами и мониторингом.</li><li><strong>Студент</strong> получает доступ к тесту, проходит его и видит собственную аналитику.</li><li><strong>Администратор</strong> сопровождает пользователей, группы и структуру доступа.</li></ul></article></div></div></section>
<section class="slide" data-title="Создание диаграммы классов"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 07</span><span>Создание диаграммы классов</span></div><h2>Классовая модель отражает учебные сущности, ролевую структуру и связи между тестированием и аналитикой</h2></div></div><div class="num">07 / 27</div></div><div class="body twowide"><div class="diag"><h3>Диаграмма классов</h3><div class="diagram-grid classes" style="margin-top:14px;"><div class="entity"><h4>User</h4><ul><li>id</li><li>full_name</li><li>login</li><li>role</li></ul></div><div class="entity"><h4>Group</h4><ul><li>id</li><li>name</li><li>teachers</li></ul></div><div class="entity"><h4>Discipline</h4><ul><li>id</li><li>title</li><li>description</li></ul></div><div class="entity"><h4>Lecture</h4><ul><li>id</li><li>title</li><li>body_text</li></ul></div><div class="entity"><h4>Test</h4><ul><li>id</li><li>title</li><li>is_published</li></ul></div><div class="entity"><h4>Question</h4><ul><li>id</li><li>text</li><li>correct_index</li></ul></div><div class="entity"><h4>Attempt</h4><ul><li>id</li><li>score</li><li>created_at</li></ul></div><div class="entity"><h4>Answer</h4><ul><li>id</li><li>attempt_id</li><li>selected_index</li></ul></div></div><p class="small" style="margin-top:16px;">Ключевая связь проекта: <strong>преподаватель + дисциплина + группа</strong> определяет доступ студентов и аналитический контур.</p></div><div><article class="quote"><h3>Ключевая идея модели</h3><p>В центре проектирования находится не отдельный тест, а цепочка учебных сущностей: дисциплина → лекция → тест → попытка → аналитика. Это позволяет интерпретировать результаты в предметном контексте.</p></article><article class="card" style="margin-top:18px;"><h3>Принцип доступа</h3><p>Преподаватель получает доступ к студентам не напрямую, а через назначение <strong>дисциплина + группа</strong>. Такая схема точнее отражает реальный учебный процесс и удобна для мониторинга успеваемости.</p></article></div></div></section>
<section class="slide" data-title="Создание диаграммы последовательностей"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 08</span><span>Создание диаграммы последовательностей</span></div><h2>Диаграмма последовательностей показывает жизненный цикл теста от лекции до сохранения результата студента</h2></div></div><div class="num">08 / 27</div></div><div class="body twowide"><div class="diag"><h3>Диаграмма последовательностей</h3><div class="flowcards" style="margin-top:14px;"><div class="flowstep"><b>1</b><h4>Преподаватель</h4><p>Создаёт лекцию и отправляет материал в систему.</p></div><div class="flowstep"><b>2</b><h4>Веб-сервис</h4><p>Передаёт текст лекции в AI-модуль для генерации вопросов.</p></div><div class="flowstep"><b>3</b><h4>AI-модуль</h4><p>Возвращает структурированный набор вопросов.</p></div><div class="flowstep"><b>4</b><h4>База данных</h4><p>Сохраняет лекцию, тест, вопросы, попытки и ответы.</p></div><div class="flowstep"><b>5</b><h4>Студент</h4><p>Проходит тест, а система возвращает результаты в аналитику.</p></div></div></div><div><article class="quote"><h3>Практический смысл</h3><p>ИИ участвует в генерации тестового материала, однако финальная публикация остаётся под контролем преподавателя. Благодаря этому сервис сочетает автоматизацию и управляемость качества.</p></article><article class="card" style="margin-top:18px;"><h3>Результат последовательности</h3><p>После прохождения теста данные не теряются, а сразу становятся частью аналитического контура по студенту, группе и дисциплине.</p></article></div></div></section>
<section class="slide" data-title="Создание диаграммы активности"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 09</span><span>Создание диаграммы активности</span></div><h2>Диаграмма активности показывает общий процесс работы преподавателя с дисциплиной и тестированием</h2></div></div><div class="num">09 / 27</div></div><div class="body twowide"><div class="diag"><h3>Диаграмма активности</h3><div class="flowcards" style="margin-top:14px;grid-template-columns:repeat(5,minmax(0,1fr));"><div class="flowstep"><b>1</b><p>Вход в систему и выбор дисциплины</p></div><div class="flowstep"><b>2</b><p>Создание лекции или импорт учебного материала</p></div><div class="flowstep"><b>3</b><p>Выбор режима: AI-генерация или ручной конструктор</p></div><div class="flowstep"><b>4</b><p>Редактирование теста и публикация доступа</p></div><div class="flowstep"><b>5</b><p>Прохождение теста и анализ результатов</p></div></div></div><div><article class="quote"><h3>Что показывает диаграмма</h3><p>В центре процесса находится преподаватель, который может выбирать между автоматической генерацией и ручным режимом, но в любом случае завершает работу одинаково: публикацией теста и анализом результатов.</p></article><article class="card" style="margin-top:18px;"><h3>Сильная сторона сервиса</h3><p>Проект не навязывает один сценарий работы: преподаватель может использовать ИИ для ускорения подготовки материалов, а затем дорабатывать их вручную.</p></article></div></div></section>
<section class="slide" data-title="Физическая модель базы данных"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 10</span><span>Физическая модель базы данных</span></div><h2>ER-диаграмма построена на реальной структуре данных проекта и отражает учебные, ролевые и аналитические связи</h2></div></div><div class="num">10 / 27</div></div><div class="body twowide"><div class="diag"><h3>ER-диаграмма</h3><div class="diagram-grid er" style="margin-top:14px;"><div class="entity"><h4>users</h4><ul><li>id</li><li>full_name</li><li>login</li><li>role</li></ul></div><div class="entity"><h4>groups</h4><ul><li>id</li><li>name</li></ul></div><div class="entity"><h4>disciplines</h4><ul><li>id</li><li>title</li><li>description</li></ul></div><div class="entity"><h4>lectures</h4><ul><li>discipline_id</li><li>teacher_id</li><li>body_text</li></ul></div><div class="entity"><h4>tests / questions</h4><ul><li>lecture_id</li><li>is_published</li><li>correct_index</li></ul></div><div class="entity"><h4>attempts / answers</h4><ul><li>student_id</li><li>test_id</li><li>selected_index</li></ul></div><div class="entity"><h4>group_teachers</h4><ul><li>group_name</li><li>teacher_id</li></ul></div><div class="entity"><h4>teaching_assignments</h4><ul><li>teacher_id</li><li>discipline_id</li><li>group_name</li></ul></div><div class="entity"><h4>teacher_disciplines</h4><ul><li>teacher_id</li><li>discipline_id</li></ul></div></div><p class="small" style="margin-top:16px;">Учебная логика сервиса строится поверх связей между преподавателем, дисциплиной, группой и фактом прохождения теста.</p></div><div><article class="quote"><h3>Ключевая особенность БД</h3><p>Модель проектировалась вокруг реального учебного сценария: преподаватель видит студентов через назначение дисциплины и группы, а не через искусственное закрепление каждого студента.</p></article><article class="card" style="margin-top:18px;"><h3>Зачем это важно</h3><p>Такой подход позволяет одной дисциплине работать сразу с несколькими группами, а одной группе — с несколькими преподавателями без разрушения аналитики.</p></article></div></div></section>
<section class="slide" data-title="Структура БД"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 11</span><span>Структура БД</span></div><h2>Структура базы данных обеспечивает хранение ролей, учебного контента, тестов и результатов прохождения</h2></div></div><div class="num">11 / 27</div></div><div class="body"><div class="three"><article class="card"><h3>users</h3><p>Содержит преподавателей, студентов и администраторов, а также данные для авторизации и профиля пользователя.</p></article><article class="card"><h3>disciplines и lectures</h3><p>Формируют учебный контур: дисциплина определяет предмет, а лекция хранит текстовый материал, по которому готовятся тесты.</p></article><article class="card"><h3>tests и questions</h3><p>Описывают контрольные материалы: заголовок теста, набор вопросов, варианты ответов и правильные индексы.</p></article><article class="card"><h3>attempts и answers</h3><p>Фиксируют прохождения тестов, выбранные ответы и расчёт итогового балла обучающегося.</p></article><article class="card"><h3>group_teachers и teaching_assignments</h3><p>Определяют, какие преподаватели работают с группой и для каких дисциплин группе открыт доступ.</p></article><article class="card"><h3>SQLite и PostgreSQL</h3><p>На этапе прототипа сервис может работать на SQLite, а для устойчивого хостинга переносится на PostgreSQL.</p></article></div><article class="quote"><h3>Практический вывод</h3><p>Структура БД покрывает как оперативную работу сервиса, так и последующую аналитическую интерпретацию результатов обучения.</p></article></div></section>
<section class="slide" data-title="Создание прототипа системы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 12</span><span>Создание прототипа системы</span></div><h2>Прототип сервиса реализован как полнофункциональное веб-приложение с серверным рендерингом, AI-модулем и ролевой моделью</h2></div></div><div class="num">12 / 27</div></div><div class="body twowide"><div><article class="quote"><h3>Архитектура решения</h3><p>Клиентский интерфейс построен на HTML, CSS и JavaScript, серверная часть реализована на FastAPI и Jinja2, а хранение данных обеспечивается SQLite или PostgreSQL. Генерация тестов опирается на внешний AI-провайдер и внутреннюю логику нормализации вопросов.</p></article><div class="grid-2" style="margin-top:18px;"><article class="card"><h3>Клиентский уровень</h3><p>Адаптивные страницы преподавателя, студента и администратора, ориентированные на реальную эксплуатацию.</p></article><article class="card"><h3>Серверный уровень</h3><p>Маршруты, авторизация, обработка лекций, публикация тестов и построение аналитики.</p></article><article class="card"><h3>AI-модуль</h3><p>Формирует тестовые вопросы по лекции и передаёт их преподавателю на валидацию и редактирование.</p></article><article class="card"><h3>Слой данных</h3><p>Хранит пользователей, группы, дисциплины, лекции, тесты, попытки и ответы.</p></article></div></div><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Главная страница прототипа</span></div><img src="presentation_assets/desktop/01_home_desktop.png" alt="Главная страница прототипа КампусПлюс"><figcaption>Стартовый экран разработанной системы</figcaption></figure></div></section>
<section class="slide" data-title="Интерфейс программы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 13</span><span>Интерфейс программы</span></div><h2>Базовые окна системы формируют отдельные рабочие контуры для разных ролей пользователей</h2></div></div><div class="num">13 / 27</div></div><div class="body"><div class="shots3"><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Главная страница</span></div><img src="presentation_assets/desktop/01_home_desktop.png" alt="Главная страница"><figcaption>Стартовый экран и точки входа в систему</figcaption></figure><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Панель преподавателя</span></div><img src="presentation_assets/desktop/04_teacher_panel_desktop.png" alt="Панель преподавателя"><figcaption>Основной контур работы преподавателя</figcaption></figure><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Панель студента</span></div><img src="presentation_assets/desktop/08_student_dashboard_desktop.png" alt="Панель студента"><figcaption>Личный кабинет обучающегося и доступные дисциплины</figcaption></figure></div></div></section>
<section class="slide" data-title="Интерфейс программы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 14</span><span>Интерфейс программы</span></div><h2>Преподавательский интерфейс позволяет работать с дисциплинами, лекциями и учебным контентом в одном окне</h2></div></div><div class="num">14 / 27</div></div><div class="body"><div class="shots2"><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Лекции и дисциплины</span></div><img src="presentation_assets/desktop/05_teacher_lectures_desktop.png" alt="Лекции и дисциплины"><figcaption>Работа с дисциплинами, лекциями и структурой учебного контента</figcaption></figure><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Ручной конструктор</span></div><img src="presentation_assets/desktop/16_teacher_manual_test_form_desktop.png" alt="Ручной конструктор теста"><figcaption>Создание и редактирование теста в ручном режиме</figcaption></figure></div></div></section>
<section class="slide" data-title="Интерфейс программы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 15</span><span>Интерфейс программы</span></div><h2>Тестовый контур включает генерацию, редактирование, публикацию и выдачу доступа через QR-код</h2></div></div><div class="num">15 / 27</div></div><div class="body"><div class="shots2"><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Список тестов</span></div><img src="presentation_assets/desktop/06_teacher_tests_desktop.png" alt="Список тестов"><figcaption>Публикация, редактирование и управление тестами</figcaption></figure><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>QR-доступ</span></div><img src="presentation_assets/desktop/07_teacher_qr_desktop.png" alt="QR-код теста"><figcaption>Быстрый доступ студентов к контрольному материалу на занятии</figcaption></figure></div></div></section>
<section class="slide" data-title="Интерфейс программы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 16</span><span>Интерфейс программы</span></div><h2>Административный контур обеспечивает сопровождение пользователей, групп и структурных связей сервиса</h2></div></div><div class="num">16 / 27</div></div><div class="body"><div class="shots2"><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Управление студентами</span></div><img src="presentation_assets/desktop/11_admin_students_desktop.png" alt="Админка студентов"><figcaption>Поиск, редактирование и сопровождение студентческого контура</figcaption></figure><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Управление группами</span></div><img src="presentation_assets/desktop/12_admin_groups_desktop.png" alt="Админка групп"><figcaption>Работа с группами и преподавателями в административной панели</figcaption></figure></div></div></section>
<section class="slide" data-title="Интерфейс программы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 17</span><span>Интерфейс программы</span></div><h2>Фронтенд сервиса адаптирован для мобильных устройств и остаётся пригодным для быстрого прохождения тестов</h2></div></div><div class="num">17 / 27</div></div><div class="body"><div class="phones"><figure class="phone"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Главная</span></div><img src="mobile_screens/01_home_mobile.png" alt="Главная на мобильном"><figcaption>Стартовый мобильный экран</figcaption></figure><figure class="phone"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Панель преподавателя</span></div><img src="mobile_screens/05_teacher_panel_mobile.png" alt="Панель преподавателя на мобильном"><figcaption>Рабочий контур преподавателя</figcaption></figure><figure class="phone"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Лекции</span></div><img src="mobile_screens/05_teacher_lectures_mobile.png" alt="Лекции на мобильном"><figcaption>Навигация по лекциям и дисциплинам</figcaption></figure><figure class="phone"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Личный кабинет</span></div><img src="mobile_screens/10_student_dashboard_mobile.png" alt="Панель студента на мобильном"><figcaption>Студентский контур на смартфоне</figcaption></figure><figure class="phone"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Тесты</span></div><img src="mobile_screens/11_student_tests_mobile.png" alt="Тесты на мобильном"><figcaption>Прохождение тестов с мобильного устройства</figcaption></figure></div></div></section>
<section class="slide" data-title="Результаты работы программы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 18</span><span>Результаты работы программы</span></div><h2>Веб-сервис обеспечивает преподавателю доступ к текущей картине успеваемости по дисциплинам и конкретным обучающимся</h2></div></div><div class="num">18 / 27</div></div><div class="body"><div class="shots2"><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Аналитика студента у преподавателя</span></div><img src="presentation_assets/desktop/14_teacher_student_performance_desktop.png" alt="Успеваемость студента у преподавателя"><figcaption>Преподаватель видит историю прохождений и результаты по конкретному студенту</figcaption></figure><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Аналитика студента</span></div><img src="presentation_assets/desktop/10_student_analytics_desktop.png" alt="Аналитика студента"><figcaption>Обучающийся получает собственную историю тестирования и итоговые показатели</figcaption></figure></div></div></section>
<section class="slide" data-title="Результаты работы программы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 19</span><span>Результаты работы программы</span></div><h2>Результаты прохождения тестов сохраняются и используются для построения персональных точек роста обучающегося</h2></div></div><div class="num">19 / 27</div></div><div class="body"><div class="shots2"><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Доступные тесты</span></div><img src="presentation_assets/desktop/09_student_tests_desktop.png" alt="Тесты студента"><figcaption>Список доступных тестов по дисциплинам преподавателя</figcaption></figure><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Точки роста</span></div><img src="presentation_assets/desktop/15_student_growth_desktop.png" alt="Точки роста студента"><figcaption>Проблемные темы и направления повторения материала</figcaption></figure></div></div></section>
<section class="slide" data-title="Результаты работы программы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 20</span><span>Результаты работы программы</span></div><h2>Административный контур позволяет сопровождать структуру данных и поддерживать корректную организацию учебного процесса</h2></div></div><div class="num">20 / 27</div></div><div class="body"><div class="metricgrid"><article class="metric"><span class="small">Роли системы</span><b>3</b><div class="small">преподаватель, студент, администратор</div></article><article class="metric"><span class="small">Режимы создания теста</span><b>2</b><div class="small">AI-генерация и ручной конструктор</div></article><article class="metric"><span class="small">Контуры аналитики</span><b>3</b><div class="small">по студенту, группе и дисциплине</div></article><article class="metric"><span class="small">Типы доступа</span><b>2</b><div class="small">через личный кабинет и QR-переход</div></article></div><div class="three"><article class="card"><h3>Реализована ролевая модель</h3><p>Разделение контуров упрощает интерфейс для пользователя и снижает риск ошибок доступа.</p></article><article class="card"><h3>Исправлены критические баги авторизации</h3><p>Усилены заголовки no-store, изоляция сессий и механизм сброса пароля.</p></article><article class="card"><h3>Введена модель «дисциплина + группа»</h3><p>Преподаватель работает со студентами через реальные учебные назначения, а не через искусственные закрепления.</p></article></div></div></section>
<section class="slide" data-title="Результаты работы программы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 21</span><span>Результаты работы программы</span></div><h2>Сервис формирует непрерывный e2e-сценарий: от создания лекции до получения аналитики после прохождения теста</h2></div></div><div class="num">21 / 27</div></div><div class="body twowide"><article class="tablebox"><table><thead><tr><th>Этап</th><th>Действие</th><th>Результат</th></tr></thead><tbody><tr><td><strong>1</strong></td><td>Преподаватель создаёт дисциплину и лекцию</td><td>В системе формируется база учебного материала</td></tr><tr><td><strong>2</strong></td><td>Преподаватель генерирует или собирает тест</td><td>Контрольный материал готов к публикации</td></tr><tr><td><strong>3</strong></td><td>Тест публикуется и выдаётся по QR-коду</td><td>Студент получает быстрый доступ без лишних шагов</td></tr><tr><td><strong>4</strong></td><td>Студент проходит тест</td><td>Попытка и ответы сохраняются в базе данных</td></tr><tr><td><strong>5</strong></td><td>Сервис строит аналитику</td><td>Преподаватель и студент видят результаты и слабые темы</td></tr></tbody></table></article><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Мониторинг успеваемости</span></div><img src="presentation_assets/desktop/14_teacher_student_performance_desktop.png" alt="Мониторинг результатов"><figcaption>Финальная точка сценария: преподаватель получает интерпретируемые результаты</figcaption></figure></div></section>
<section class="slide" data-title="Результаты работы программы"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 22</span><span>Результаты работы программы</span></div><h2>В ходе разработки сервис был доведён до уровня демонстрационного стенда с реальными пользовательскими сценариями</h2></div></div><div class="num">22 / 27</div></div><div class="body"><div class="three"><article class="card"><h3>Реальный фронтенд</h3><p>В презентации используются скриншоты фактической реализации, а не макеты, что подтверждает прикладную готовность решения.</p></article><article class="card"><h3>Живой пользовательский цикл</h3><p>Преподаватель, студент и администратор работают с одним и тем же сервисом, а не с разрозненными демонстрационными экранами.</p></article><article class="card"><h3>Адаптация под эксплуатацию</h3><p>Учтены мобильные сценарии, авторизация, сброс пароля, распределение ролей и поддержка нескольких преподавателей у группы.</p></article></div><article class="quote"><h3>Итог промежуточного этапа</h3><p>Разработанный сервис можно демонстрировать комиссии как рабочую систему: он реализует заданную архитектуру, решает прикладную задачу преподавателя и уже проходит ручное тестирование на реальных сценариях использования.</p></article></div></section>
<section class="slide" data-title="Заключение"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 23</span><span>Заключение</span></div><h2>В ходе выполнения работы был разработан веб-сервис, который автоматизирует подготовку тестирования и обеспечивает мониторинг успеваемости</h2></div></div><div class="num">23 / 27</div></div><div class="body twowide"><div><article class="quote"><h3>Основной результат</h3><p>Разработан прикладной веб-сервис для мониторинга успеваемости с применением технологий искусственого интеллекта, объединяющий лекционный материал, тестирование, публикацию доступа и предметную аналитику.</p></article><ul class="list" style="margin-top:18px;"><li>Проведён анализ предметной области и существующих решений.</li><li>Обоснован выбор программных средств и архитектуры проекта.</li><li>Построены функциональные и информационно-логические модели системы.</li><li>Разработан веб-прототип с ролями преподавателя, студента и администратора.</li><li>Показана работоспособность сервиса на реальных пользовательских сценариях.</li></ul></div><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Итоговый контур</span></div><img src="presentation_assets/desktop/04_teacher_panel_desktop.png" alt="Итоговый экран проекта"><figcaption>Рабочий интерфейс преподавателя как итог реализации проекта</figcaption></figure></div></section>
<section class="slide" data-title="Апробации"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 24</span><span>Апробации</span></div><h2>Раздел апробации будет дополнен подтверждающими материалами, сертификатами и ссылками на публикации</h2></div></div><div class="num">24 / 27</div></div><div class="body"><article class="placeholder"><div class="inner"><div class="kicker">Материал под подготовку</div><h3 style="margin:16px 0 12px;">Слайд будет дополнен</h3><p>На этом слайде планируется разместить сведения об апробации, публикациях, конференциях и сопроводительные QR-коды на подтверждающие материалы.</p></div></article></div></section>
<section class="slide" data-title="Акт внедрения"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 25</span><span>Акт внедрения</span></div><h2>Раздел акта внедрения будет дополнен после окончательного согласования размещения и эксплуатационного контура</h2></div></div><div class="num">25 / 27</div></div><div class="body"><article class="placeholder"><div class="inner"><div class="kicker">Материал под подготовку</div><h3 style="margin:16px 0 12px;">Слайд будет дополнен</h3><p>Планируется размещение акта внедрения, подписи ответственных лиц и QR-кода на подтверждающие документы.</p></div></article></div></section>
<section class="slide" data-title="Результаты внедрения"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 26</span><span>Результаты внедрения</span></div><h2>Раздел результатов внедрения будет дополнен после сбора эксплуатационных метрик и обратной связи пользователей</h2></div></div><div class="num">26 / 27</div></div><div class="body"><article class="placeholder"><div class="inner"><div class="kicker">Материал под подготовку</div><h3 style="margin:16px 0 12px;">Слайд будет дополнен</h3><p>Здесь будут размещены показатели эффективности внедрения, сводные выводы по эксплуатации и QR-коды на подтверждающие материалы.</p></div></article></div></section>
<section class="slide" data-title="Финальный слайд"><div class="top"><div class="brand"><div class="logo"><img src="app/static/img/sgugit-mark.png" alt="СГУГиТ"></div><div><div class="meta"><span>Слайд 27</span><span>Спасибо за внимание</span></div><h2>Разработка веб-сервиса для мониторинга успеваемости с применением технологий искусственого интеллекта</h2></div></div><div class="num">27 / 27</div></div><div class="body twowide"><div><article class="quote"><h3>Спасибо за внимание</h3><p><strong>Обучающийся:</strong> Енчу Роман Викторович<br><strong>Группа:</strong> БИ-41<br><strong>Руководитель:</strong> Басаргин А.А.</p></article><article class="card" style="margin-top:18px;"><h3>Контур проекта</h3><p>КампусПлюс подготовлен как демонстрационный стенд ВКР и может быть дополнен материалами апробации, актом внедрения и расширенной эксплуатационной аналитикой.</p></article></div><figure class="screen"><div class="bar"><span class="dots"><i></i><i></i><i></i></span><span>Демонстрационный стенд проекта</span></div><img src="presentation_assets/desktop/04_teacher_panel_desktop.png" alt="Финальный экран КампусПлюс"><figcaption>Финальный экран презентации</figcaption></figure></div></section>
<div class="footer"><button class="nav sec" id="prevBtn" type="button">Предыдущий слайд</button><div><div class="counter" id="counter">01 / 27</div><div class="progress"><span id="progressBar"></span></div></div><button class="nav" id="nextBtn" type="button">Следующий слайд</button></div></div></div>
<div class="lightbox" id="lightbox" aria-hidden="true"><button class="close" id="closeLightbox" type="button" aria-label="Закрыть">×</button><figure><img id="lightboxImage" alt=""><figcaption id="lightboxCaption"></figcaption></figure></div>
<script>
const slides=[...document.querySelectorAll('.slide')];const counter=document.getElementById('counter');const progressBar=document.getElementById('progressBar');const prevBtn=document.getElementById('prevBtn');const nextBtn=document.getElementById('nextBtn');const lightbox=document.getElementById('lightbox');const lightboxImage=document.getElementById('lightboxImage');const lightboxCaption=document.getElementById('lightboxCaption');const closeLightbox=document.getElementById('closeLightbox');let current=0;
function pad(v){return String(v).padStart(2,'0')}function show(i){const n=Math.max(0,Math.min(i,slides.length-1));slides[current].classList.remove('active');current=n;slides[current].classList.add('active');counter.textContent=`${pad(current+1)} / ${pad(slides.length)}`;progressBar.style.width=`${((current+1)/slides.length)*100}%`;document.title=`${slides[current].dataset.title} — КампусПлюс`;history.replaceState(null,'',`#${current+1}`)}
function openImage(img){lightboxImage.src=img.currentSrc||img.src;lightboxImage.alt=img.alt||'';const cap=img.closest('figure')?.querySelector('figcaption');lightboxCaption.textContent=cap?cap.textContent:(img.alt||'');lightbox.classList.add('open');lightbox.setAttribute('aria-hidden','false')}function closeImage(){lightbox.classList.remove('open');lightbox.setAttribute('aria-hidden','true');lightboxImage.src=''}
prevBtn.addEventListener('click',()=>show(current-1));nextBtn.addEventListener('click',()=>show(current+1));closeLightbox.addEventListener('click',closeImage);lightbox.addEventListener('click',e=>{if(e.target===lightbox)closeImage()});document.querySelectorAll('.screen img,.phone img').forEach(img=>img.addEventListener('click',()=>openImage(img)));
document.addEventListener('keydown',e=>{if(lightbox.classList.contains('open')){if(e.key==='Escape')closeImage();return}if(['ArrowRight','PageDown',' '].includes(e.key)){e.preventDefault();show(current+1)}if(['ArrowLeft','PageUp'].includes(e.key)){e.preventDefault();show(current-1)}if(e.key==='Home')show(0);if(e.key==='End')show(slides.length-1)});
let touchStartX=0;document.addEventListener('touchstart',e=>{touchStartX=e.changedTouches[0].screenX},{passive:true});document.addEventListener('touchend',e=>{if(lightbox.classList.contains('open'))return;const d=touchStartX-e.changedTouches[0].screenX;if(Math.abs(d)<48)return;show(d>0?current+1:current-1)},{passive:true});
const initial=Number.parseInt(window.location.hash.replace('#',''),10);show(Number.isFinite(initial)?initial-1:0);
</script>
</body>
</html>
